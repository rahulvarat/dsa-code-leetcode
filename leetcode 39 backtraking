class Solution {
public:

    void fun(vector<int>&arr,int n,int idx,vector<int>&dairy,int sum,vector<vector<int>>&res,int target){
        
      
        if(sum == target){
            res.push_back(dairy);
            return;
        }
        
        if(idx == n || sum > target){
            return;
        }

        fun(arr,n,idx+1,dairy,sum,res,target);

     
        if(arr[idx] + sum <= target){
            dairy.push_back(arr[idx]);
            
         
            fun(arr,n,idx,dairy,sum + arr[idx],res,target);
             
            dairy.pop_back();
        }
    }

    vector<vector<int>> combinationSum(vector<int>& arr, int target) {
        int n=arr.size();
        int sum=0;
        int idx=0;
        vector<int>dairy;
        vector<vector<int>>res;

        fun(arr,n,idx,dairy,sum,res,target);

        return res;
    }
};
